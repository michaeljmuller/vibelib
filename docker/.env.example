# S3-compatible object store
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_REGION=us-east-1
S3_ENDPOINT=https://us-east-1.linodeobjects.com
S3_BUCKET=michaeljmuller-media

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# VPN (gluetun) — used to tunnel service container outbound traffic
VPN_PROVIDER=ivpn
VPN_TYPE=wireguard
VPN_WIREGUARD_PRIVATE_KEY=your_wireguard_private_key_here
VPN_WIREGUARD_ADDRESS=your_wireguard_address_here
VPN_SERVER_COUNTRY=Sweden

# Bootstrap tool
DATABASE_URL=postgresql://library:library@postgres:5432/library
BOOTSTRAP_CACHE_DIR=./data/bootstrap_cache
# Optional tuning (defaults shown)
# AMAZON_DELAY_MIN=5
# AMAZON_DELAY_MAX=15
# FUZZY_MATCH_THRESHOLD=85
# DRY_RUN=1
# LIMIT_KEYS=key1.epub,key2.epub
# MAX_FILES=10
